<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Compose-only app: we don't use AppCompat/XML widgets so we anchor to the system
        Material theme and let Compose draw everything. Edge-to-edge and the status / nav bar
        appearance are set from [MockLocationTheme] in code, so the XML theme only needs to
        hide the action bar and expose a matching window background for the launch screen.
    -->
    <style name="Theme.MockLocation" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
    </style>
</resources>
